<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BarcodeApp.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="1280"
    d:DesignHeight="760"
        x:Class="BarcodeApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
    Title="EAN to ZPL">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="16" RowSpacing="10">
        <Border Grid.Row="0" Padding="12" CornerRadius="8" Background="#F2F7FF" BorderBrush="#C9D8F2" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                <Button Content="Import CSV/XLS" Click="ImportFileButton_OnClick"/>
                <Button Grid.Column="1" Content="Add Row" Command="{Binding AddRowCommand}"/>
                <Button Grid.Column="2" Content="Remove Selected" Command="{Binding RemoveSelectedRowCommand}"/>
                <Button Grid.Column="4" Content="Clear" Command="{Binding ClearRowsCommand}"/>
                <CheckBox Grid.Column="5" Content="Include Product Name In Label" IsChecked="{Binding IncludeProductName}" VerticalAlignment="Center"/>
                <Button Grid.Column="6" Content="Export ZPL" Click="ExportZplButton_OnClick"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="10">
            <TextBlock VerticalAlignment="Center" Text="Valid:" FontWeight="Bold"/>
            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding ValidRowsCount}"/>
            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Invalid:" FontWeight="Bold"/>
            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding InvalidRowsCount}"/>
            <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="Labels:" FontWeight="Bold"/>
            <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="{Binding TotalLabels}"/>
        </Grid>

        <Border Grid.Row="2" BorderThickness="1" BorderBrush="#D0D0D0" CornerRadius="6">
            <Grid RowDefinitions="Auto,*">
                <Border Background="#EDF2FB" Padding="8" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="220,*,130,380,Auto" ColumnSpacing="8">
                        <TextBlock Text="EAN-13" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="Product Name" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="Quantity" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="Validation" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="Actions" FontWeight="Bold"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" MaxHeight="420">
                    <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E6E6E6" BorderThickness="0,0,0,1" Padding="8">
                                    <Grid ColumnDefinitions="220,*,130,380,Auto" ColumnSpacing="8">
                                        <TextBox Text="{Binding Ean, Mode=TwoWay}" PlaceholderText="13-digit EAN"/>
                                        <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}" PlaceholderText="Product name"/>
                                        <TextBox Grid.Column="2" Text="{Binding QuantityText, Mode=TwoWay}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ValidationMessage}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                        <Button Grid.Column="4" Content="Remove" Click="RemoveRowButton_OnClick" Tag="{Binding .}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="3" Padding="12" CornerRadius="8" Background="#F8F8F8" BorderBrush="#D9D9D9" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,200,Auto,80,Auto,*" ColumnSpacing="8">
                <TextBlock VerticalAlignment="Center" Text="Printer host/IP:" FontWeight="Bold"/>
                <TextBox Grid.Column="1" Text="{Binding PrinterHost, Mode=TwoWay}" PlaceholderText="e.g. 192.168.1.40"/>

                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Port:" FontWeight="Bold"/>
                <TextBox Grid.Column="3" Text="{Binding PrinterPort, Mode=TwoWay}"/>

                <Button Grid.Column="4" Content="Send To Printer" Command="{Binding SendToPrinterCommand}"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Padding="10" CornerRadius="6" Background="#FFF7E6" BorderBrush="#E0C899" BorderThickness="1">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
        </Border>
    </Grid>

</Window>
