<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Qivisoft.BarcodeApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="760"
        x:Class="Qivisoft.BarcodeApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Icon="/Assets/avalonia-logo.ico"
        Title="QiviLabel">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto" Margin="16" RowSpacing="10">
        <Border Grid.Row="0" Padding="12" Classes="surface-card toolbar-card">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <Button Content="Importuj CSV/XLS" Click="ImportFileButton_OnClick" />
                <Button Grid.Column="1" Content="Dodaj wiersz" Command="{Binding AddRowCommand}" />
                <Button Grid.Column="2" Content="Usuń zaznaczony" Command="{Binding RemoveSelectedRowCommand}" />
                <Button Grid.Column="4" Content="Wyczyść" Command="{Binding ClearRowsCommand}" />
                <CheckBox Grid.Column="5" Content="Uwzględnij nazwę produktu na etykiecie"
                          IsChecked="{Binding IncludeProductName, Mode=TwoWay}"
                          IsThreeState="False"
                          VerticalAlignment="Center" />
                <Button Grid.Column="6" Content="Eksportuj do pliku ZPL" Click="ExportZplButton_OnClick"
                        IsEnabled="{Binding CanExport}" />
                <Button Grid.Column="7" Content="Drukuj ZPL na ZEBRA" Click="PrintZplButton_OnClick"
                    IsEnabled="{Binding CanPrint}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="10">
            <TextBlock VerticalAlignment="Center" Text="Poprawne:" Classes="section-label" />
            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding ValidRowsCount}" />
            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Błędne:" Classes="section-label" />
            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding InvalidRowsCount}" />
            <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="Etykiety:" Classes="section-label" />
            <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="{Binding TotalLabels}" />
        </Grid>

        <Border Grid.Row="2" Classes="table-shell">
            <Grid RowDefinitions="Auto,*">
                <Border Padding="8" BorderThickness="0,0,0,1" Classes="table-header">
                    <Grid ColumnDefinitions="220,*,130,380,Auto" ColumnSpacing="8">
                        <TextBlock Text="Kod kreskowy" />
                        <TextBlock Grid.Column="1" Text="Nazwa produktu" />
                        <TextBlock Grid.Column="2" Text="Ilość" />
                        <TextBlock Grid.Column="3" Text="Walidacja" />
                        <TextBlock Grid.Column="4" Text="Akcje" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                              MaxHeight="420">
                    <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Classes="table-row">
                                    <Grid ColumnDefinitions="220,*,130,380,Auto" ColumnSpacing="8">
                                        <TextBox Text="{Binding Ean, Mode=TwoWay}" PlaceholderText="Wartość kodu" />
                                        <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"
                                                 PlaceholderText="Nazwa produktu" />
                                        <TextBox Grid.Column="2" Text="{Binding QuantityText, Mode=TwoWay}" />
                                        <TextBlock Grid.Column="3" Text="{Binding ValidationMessage}"
                                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                                        <Button Grid.Column="4" Content="Usuń" Click="RemoveRowButton_OnClick"
                                                Tag="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Label size settings panel -->
        <Border Grid.Row="3" Padding="10" Classes="surface-card">
            <Expander IsExpanded="False">
                <Expander.Header>
                    <TextBlock Text="Ustawienia etykiety i drukarki" Classes="section-label" />
                </Expander.Header>

                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <TextBlock Text="Rozmiar etykiety" Classes="section-label" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Przywróć domyślne" Command="{Binding ResetSettingsCommand}" />
                    </Grid>

                <Grid ColumnDefinitions="Auto,220,Auto,Auto,Auto,*" ColumnSpacing="8">
                    <TextBlock VerticalAlignment="Center" Text="Profil drukarki:" Classes="section-label" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding PrinterProfileNames}"
                              SelectedItem="{Binding SelectedPrinterProfileName, Mode=TwoWay}" />
                    <Button Grid.Column="2" Content="Nowy profil" Command="{Binding AddProfileCommand}" />
                    <Button Grid.Column="3" Content="Usuń profil" Command="{Binding RemoveProfileCommand}" />
                    <Button Grid.Column="4" Content="Preset 203" Command="{Binding Apply203DpiPresetCommand}" />
                    <Button Grid.Column="5" HorizontalAlignment="Left" Content="Preset 300" Command="{Binding Apply300DpiPresetCommand}" />
                </Grid>

                <Grid ColumnDefinitions="Auto,220,*" ColumnSpacing="10">
                    <TextBlock VerticalAlignment="Center" Text="Typ kodu:" Classes="section-label" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding BarcodeTypeOptions}"
                              SelectedItem="{Binding SelectedBarcodeType, Mode=TwoWay}" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"
                               Text="{Binding BarcodeTypeHint}" Opacity="0.65" TextWrapping="Wrap" />
                </Grid>

                <Grid ColumnDefinitions="Auto,Auto,220,Auto,Auto,220,*" ColumnSpacing="10">
                    <TextBlock VerticalAlignment="Center" Text="Drukarka USB (kolejka):" Classes="section-label" />
                    <Border Grid.Column="1" Width="18" Height="18" CornerRadius="9" BorderThickness="1"
                            BorderBrush="{DynamicResource SurfaceBorderBrush}" VerticalAlignment="Center"
                            ToolTip.Tip="To nazwa kolejki drukarki z systemu (CUPS), np. Zebra_USB. Jak znaleźć: Ustawienia systemowe → Drukarki i skanery, albo komenda: lpstat -p">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="i" FontWeight="Bold" Opacity="0.75" />
                    </Border>
                    <TextBox Grid.Column="2" Text="{Binding PrinterQueueName, Mode=TwoWay}" PlaceholderText="np. Zebra_USB" />
                    <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Host/IP ZEBRA:" Classes="section-label" />
                    <Border Grid.Column="4" Width="18" Height="18" CornerRadius="9" BorderThickness="1"
                            BorderBrush="{DynamicResource SurfaceBorderBrush}" VerticalAlignment="Center"
                            ToolTip.Tip="Użyj dla drukarki sieciowej Zebra. IP sprawdzisz na etykiecie konfiguracyjnej drukarki lub w panelu routera. Dla Zebra RAW zwykle używa się portu 9100.">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="i" FontWeight="Bold" Opacity="0.75" />
                    </Border>
                    <TextBox Grid.Column="5" Text="{Binding PrinterHost, Mode=TwoWay}" PlaceholderText="np. 192.168.1.55" />
                    <TextBlock Grid.Column="6" VerticalAlignment="Center" Margin="10,0,0,0"
                               Text="USB: wpisz kolejkę. Sieć: wpisz Host/IP + port poniżej." Opacity="0.65" />
                </Grid>

                <Grid ColumnDefinitions="Auto,Auto,110,*" ColumnSpacing="10">
                    <TextBlock VerticalAlignment="Center" Text="Port ZEBRA:" Classes="section-label" />
                    <Border Grid.Column="1" Width="18" Height="18" CornerRadius="9" BorderThickness="1"
                            BorderBrush="{DynamicResource SurfaceBorderBrush}" VerticalAlignment="Center"
                            ToolTip.Tip="Port dla drukarki sieciowej Zebra. Najczęściej: 9100 (RAW). Jeśli nie działa, sprawdź ustawienia portu w konfiguracji drukarki.">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="i" FontWeight="Bold" Opacity="0.75" />
                    </Border>
                    <TextBox Grid.Column="2" Text="{Binding PrinterPortText, Mode=TwoWay}" />
                    <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="10,0,0,0"
                               Text="Standard dla ZEBRA TCP: 9100" Opacity="0.65" />
                </Grid>

                <!-- DPI row -->
                <Grid ColumnDefinitions="Auto,110,*" ColumnSpacing="10">
                    <TextBlock VerticalAlignment="Center" Text="DPI drukarki:" Classes="section-label" />
                    <ComboBox Grid.Column="1"
                              SelectedItem="{Binding PrinterDpi, Mode=TwoWay}">
                        <ComboBox.Items>
                            <x:Int32>203</x:Int32>
                            <x:Int32>300</x:Int32>
                        </ComboBox.Items>
                    </ComboBox>
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"
                               Text="{Binding DpiHint}" Opacity="0.65" />
                </Grid>

                <!-- Dot fields row -->
                <Grid ColumnDefinitions="Auto,96,Auto,16,Auto,96,Auto,16,Auto,96,Auto" ColumnSpacing="6">
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Szerokość (dots):" Classes="section-label" />
                    <TextBox Grid.Column="1" Text="{Binding LabelWidthDotsText, Mode=TwoWay}" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="4,0,0,0"
                               Text="{Binding LabelWidthMm}" Opacity="0.65" />

                    <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="Wys. kodu (dots):" Classes="section-label"
                               ToolTip.Tip="Wysokość pionowych kresek kodu kreskowego. Np. 110 dots ≈ 14 mm przy 203 dpi. Nie wpływa na rozmiar etykiety." />
                    <TextBox Grid.Column="5" Text="{Binding BarcodeHeightDotsText, Mode=TwoWay}"
                             ToolTip.Tip="Standardowe wartości: 80–150. Wyższy kod = łatwiejszy odczyt przez skaner." />
                    <TextBlock Grid.Column="6" VerticalAlignment="Center" Margin="4,0,0,0"
                               Opacity="0.65" Text="kreski" />

                    <TextBlock Grid.Column="8" VerticalAlignment="Center" Text="Wys. etykiety (dots):" Classes="section-label"
                               ToolTip.Tip="Całkowita wysokość etykiety. Zostaw 0, jeśli drukarka ma mierzyć etykietę automatycznie (gap detection)." />
                    <TextBox Grid.Column="9" Text="{Binding LabelHeightDotsText, Mode=TwoWay}"
                             ToolTip.Tip="0 = drukarka mierzy etykietę sama. Wpisz np. 400, by wydrukować zawsze etykietę o wysokości 400 dots ≈ 50 mm (przy 203 dpi)." />
                    <TextBlock Grid.Column="10" VerticalAlignment="Center" Margin="4,0,0,0"
                               Text="{Binding LabelHeightMm}" Opacity="0.65" />
                </Grid>

                <!-- Tips box -->
                <Border Padding="10,8" CornerRadius="6" BorderThickness="1" Opacity="0.9"
                        Background="{DynamicResource TableHeaderBackgroundBrush}"
                        BorderBrush="{DynamicResource SurfaceBorderBrush}">
                    <StackPanel Spacing="3">
                        <TextBlock FontWeight="SemiBold" Text="Wskazówki" />
                        <TextBlock TextWrapping="Wrap"
                                   Text="Szerokość etykiety: sprawdź fizyczny rozmiar rolki. Np. rolka 75 mm → 600 dots przy 203 dpi, lub 900 dots przy 300 dpi." />
                        <TextBlock TextWrapping="Wrap"
                                   Text="Dla wielu drukarek utwórz osobne profile i przełączaj je z listy, zamiast ręcznie przepisywać ustawienia." />
                        <TextBlock TextWrapping="Wrap"
                                   Text="Wys. kodu: to tylko wysokość kresek, nie całej etykiety. Typowa wartość 80–130. Większa = łatwiejszy odczyt." />
                        <TextBlock TextWrapping="Wrap"
                                   Text="Wys. etykiety: zostaw 0, jeśli nie wiesz — drukarka zmierzy etykietę sama (gap detection). Wpisz wartość tylko gdy etykiety są ciągłe (bez przerw) lub wydruk jest obcięty." />
                    </StackPanel>
                </Border>
                </StackPanel>
            </Expander>
        </Border>

        <Border Grid.Row="4" Padding="10" CornerRadius="6" BorderThickness="1" Classes="surface-card status-card">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                    <TextBlock Text="Trwa drukowanie..." Opacity="0.7" IsVisible="{Binding IsPrintInProgress}" />
                </StackPanel>
                <Button Grid.Column="1" Content="Jak używać?" Click="ShowHelpButton_OnClick" />
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="5" ColumnDefinitions="*,Auto" Margin="2,0">
            <TextBlock VerticalAlignment="Center" FontSize="11" Opacity="0.5"
                       Text="Made with &#x2764;&#xFE0F;, Qivisoft" />
            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="11" Opacity="0.5"
                       Text="qivisoft@gmail.com" />
        </Grid>
    </Grid>

</Window>